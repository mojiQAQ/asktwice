{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.2.0",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_CN",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "config.js",
        "shared/i18n-data.js",
        "shared/constants.js",
        "shared/utils.js",
        "shared/api.js",
        "shared/storage.js",
        "content/platforms/config.js",
        "content/platforms/doubao.js",
        "content/platforms/chatgpt.js",
        "content/ui/float-button.js",
        "content/ui/result-card.js",
        "content/ui/selection-bubble.js",
        "content/extractor.js",
        "content/index.js"
      ],
      "css": [
        "content/styles/inject.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
